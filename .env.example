# PostgreSQL (used by Docker and Django)
POSTGRES_DB=poke_chaser
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MailHog (SMTP)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@pokechaser.local

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,app
FRONTEND_URL=http://localhost:5173

# Pokemon TCG API (https://dev.pokemontcg.io)
POKEMON_TCG_API_KEY=your-key-from-dev.pokemontcg.io
